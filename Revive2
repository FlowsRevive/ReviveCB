        for _, player in ipairs(Players:GetPlayers()) do
            if player.Character then
                local highlight = player.Character:FindFirstChild("PlayerHighlight")
                if highlight then highlight:Destroy() end
            end
        end
        
        for _, conn in ipairs(connections) do
            if conn.Connected then conn:Disconnect() end
        end
        
        if fovCircle then fovCircle:Remove() end
        for _, drawings in pairs(espDrawings) do
            if drawings then 
                if drawings.text then drawings.text:Remove() end
                if drawings.bg then drawings.bg:Remove() end
                if drawings.bar then drawings.bar:Remove() end
                if drawings.outline then drawings.outline:Remove() end
            end
        end
        table.clear(espDrawings)
        
        local camera = workspace.CurrentCamera
        local viewLight = camera:FindFirstChild("ViewmodelLight")
        if viewLight then viewLight:Destroy() end
        
        if hitSound then hitSound:Destroy() end
        
        Rayfield:Destroy()
    end,
})

Rayfield:LoadConfiguration()
