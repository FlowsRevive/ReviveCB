-- UPGRADED: Multipoint Hitbox & Smart Penetration Raycasting
local function isPointVisible(character, pointPos)
    local camera = workspace.CurrentCamera
    local origin = camera.CFrame.Position
    local direction = pointPos - origin

    local raycastParams = RaycastParams.new()
    local ignoreList = {LocalPlayer.Character, camera}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.IgnoreWater = true

    local maxRetries = 30
    local retries = 0

    while retries < maxRetries do
        raycastParams.FilterDescendantsInstances = ignoreList
        local result = workspace:Raycast(origin, direction, raycastParams)

        if result then
            if result.Instance:IsDescendantOf(character) then
                return true
            else
                local inst = result.Instance
                local name = string.lower(inst.Name)
                
                local isInvisible = inst.Transparency >= 0.5
                local isNonSolid = not inst.CanCollide
                local isGlass = inst.Material == Enum.Material.Glass
                local isMapClip = name:find("clip") or name:find("fence") or name:find("rail") or name:find("grate") or name:find("window") or name:find("transparent") or name:find("shoot") or name:find("bars") or name:find("mesh") or name:find("wire") or name:find("gate") or name:find("chain") or name:find("pole") or name:find("ladder") or name:find("step") or name:find("stair")
                
                if isInvisible or isNonSolid or isGlass or isMapClip then
                    table.insert(ignoreList, inst)
                    retries = retries + 1
                else
                    return false 
                end
            end
        else
            return true
        end
    end
    return false
end

local function isCharacterVisible(character, specificPart)
    if specificPart then
        local offsets = {
            Vector3.new(0, 0, 0), -- Center
            Vector3.new(specificPart.Size.X / 2.5, 0, 0), -- Right
            Vector3.new(-specificPart.Size.X / 2.5, 0, 0), -- Left
            Vector3.new(0, specificPart.Size.Y / 2.5, 0), -- Top
            Vector3.new(0, -specificPart.Size.Y / 2.5, 0) -- Bottom
        }
        
        for _, offset in ipairs(offsets) do
            local pointPos = specificPart.CFrame * offset
            if isPointVisible(character, pointPos) then
                return true, pointPos
            end
        end
        return false, nil
    end
    
    local partsToCheck = {"Head", "HumanoidRootPart", "UpperTorso", "LowerTorso"}
    for _, partName in ipairs(partsToCheck) do
        local p = character:FindFirstChild(partName)
        if p and isPointVisible(character, p.Position) then
            return true, p.Position
        end
    end
    return false, nil
end

