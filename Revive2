local function createTracer(startPos, endPos)
    local distance = (endPos - startPos).Magnitude
    local tracer = Instance.new("Part")
    tracer.Anchored = true
    tracer.CanCollide = false
    tracer.Material = Enum.Material.Neon
    tracer.Color = tracerColor
    tracer.Transparency = 0.1
    tracer.Size = Vector3.new(0.04, 0.04, distance)
    tracer.CFrame = CFrame.lookAt(startPos, endPos) * CFrame.new(0, 0, -distance / 2)
    tracer.CastShadow = false
    tracer.Parent = workspace
    
    local tweenInfo = TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    local tween = TweenService:Create(tracer, tweenInfo, {
        Transparency = 1, 
        Size = Vector3.new(0, 0, distance)
    })
    
    tween:Play()
    tween.Completed:Connect(function()
        tracer:Destroy()
    end)
end

local function getTracerOrigin()
    local character = LocalPlayer.Character
    if character then
        local tool = character:FindFirstChildOfClass("Tool")
        if tool then
            local name = string.lower(tool.Name)
            local ignoredWeapons = {"knife", "karambit", "bayonet", "butterfly", "c4", "bomb", "grenade", "smoke", "flashbang", "molotov", "decoy", "melee"}
            for _, ignored in ipairs(ignoredWeapons) do
                if name:find(ignored) then return nil end 
            end
        end
    end

    local camera = workspace.CurrentCamera
    local viewModel = camera:FindFirstChild("ViewModel") or camera:FindFirstChild("Arms") or camera:FindFirstChildWhichIsA("Model")
    
    if viewModel then
        for _, child in ipairs(viewModel:GetChildren()) do
            local cName = string.lower(child.Name)
            if cName:find("knife") or cName:find("c4") or cName:find("grenade") then 
                return nil 
            end
        end
        for _, part in ipairs(viewModel:GetDescendants()) do
            if part:IsA("BasePart") then
                local lname = part.Name:lower()
                if lname:find("barrel") or lname:find("muzzle") or lname:find("flash") then
                    return part.Position
                end
            end
        end
    end

    if character then
        local tool = character:FindFirstChildOfClass("Tool")
        if tool and tool:FindFirstChild("Handle") then
            return tool.Handle.Position
        end
    end

    return workspace.CurrentCamera.CFrame.Position - Vector3.new(0, 0.5, 0)
end

