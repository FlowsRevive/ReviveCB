                            drawings.text.Position = Vector2.new(screenPos.X, screenPos.Y)
                            
                            local highlight = player.Character:FindFirstChild("PlayerHighlight")
                            if highlight then
                                drawings.text.Color = highlight.FillColor
                            else
                                if gameMode == "Free For All" then drawings.text.Color = ENEMY_COLOR
                                elseif LocalPlayer.Team and player.Team and LocalPlayer.Team == player.Team then drawings.text.Color = TEAMMATE_COLOR
                                else drawings.text.Color = ENEMY_COLOR end
                            end
                            
                            drawings.bg.Size = Vector2.new(barWidth, barHeight)
                            drawings.bg.Position = Vector2.new(barX, barY)
                            
                            drawings.bar.Size = Vector2.new(barWidth * healthPct, barHeight)
                            drawings.bar.Position = Vector2.new(barX, barY)
                            drawings.bar.Color = Color3.new(1 - healthPct, healthPct, 0)
                            
                            drawings.outline.Size = Vector2.new(barWidth, barHeight)
                            drawings.outline.Position = Vector2.new(barX, barY)
                            
                            drawings.text.Visible = true
                            drawings.bg.Visible = true
                            drawings.bar.Visible = true
                            drawings.outline.Visible = true
                        else
                            drawings.text.Visible = false
                            drawings.bg.Visible = false
                            drawings.bar.Visible = false
                            drawings.outline.Visible = false
                        end
                    else
                        drawings.text.Visible = false
                        drawings.bg.Visible = false
                        drawings.bar.Visible = false
                        drawings.outline.Visible = false
                    end
                end
            end
        end
    else
        for _, drawings in pairs(espDrawings) do
            if drawings and drawings.text then 
                drawings.text.Visible = false 
                drawings.bg.Visible = false
                drawings.bar.Visible = false
                drawings.outline.Visible = false
            end
        end
    end

    -- Auto Shoot (TriggerBot with FOV & Aimbot)
    local isAutoShooting = false
    if autoShootEnabled then
        local closestEnemy = nil
        local bestTargetPart = nil
        local bestTargetPos = nil
        local shortestDistance = fovRadius
        local camera = workspace.CurrentCamera
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                local isEnemy = true
                if gameMode == "Team Based" then
                    if LocalPlayer.Team and player.Team and LocalPlayer.Team == player.Team then
                        isEnemy = false
                    end
                end
                
                if isEnemy and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
                    
                    local targetPart = nil
                    if aimPartChoice == "Head" then
                        targetPart = player.Character:FindFirstChild("Head") or player.Character.HumanoidRootPart
                    elseif aimPartChoice == "Torso" then
                        targetPart = player.Character.HumanoidRootPart
                    elseif aimPartChoice == "Random" then
                        if currentTargetEnemy == player.Character and currentRandomPart and currentRandomPart.Parent == player.Character then
                            targetPart = currentRandomPart
                        else
                            local possibleParts = {}
                            for _, name in ipairs({"Head", "HumanoidRootPart", "Left Arm", "Right Arm", "Left Leg", "Right Leg", "UpperTorso", "LowerTorso"}) do
                                local p = player.Character:FindFirstChild(name)
                                if p then table.insert(possibleParts, p) end
                            end
                            targetPart = #possibleParts > 0 and possibleParts[math.random(1, #possibleParts)] or player.Character.HumanoidRootPart
                        end
                    end
                    
                    if targetPart then
                        local screenPos, onScreen = camera:WorldToViewportPoint(targetPart.Position)
                        
                        if onScreen then
                            local distance = (Vector2.new(screenPos.X, screenPos.Y) - mouseLocationViewport).Magnitude
                            if distance <= shortestDistance then
                                local isVisible, visPos = isCharacterVisible(player.Character, targetPart)
                                
                                if isVisible then
                                    closestEnemy = player.Character
                                    shortestDistance = distance
                                    bestTargetPart = targetPart
                                    bestTargetPos = visPos
                                end
                            end
                        end
                    end
                end
            end
        end
        
        if closestEnemy and bestTargetPart and bestTargetPos then
            if lastSeenEnemy == closestEnemy then
                timeInSight = timeInSight + deltaTime
            else
                lastSeenEnemy = closestEnemy
                timeInSight = 0
            end

            if timeInSight >= triggerDelay then
                isAutoShooting = true
                
                currentTargetEnemy = closestEnemy
                currentRandomPart = bestTargetPart
                
                local predictedPos = bestTargetPos
                if bestTargetPart.Velocity.Magnitude > 1 then
                    predictedPos = predictedPos + (bestTargetPart.Velocity * 0.04) 
                end
                
                if aimMethod == "Mouse" and typeof(mousemoverel) == "function" then
                    local screenPos = camera:WorldToScreenPoint(predictedPos)
                    local mousePos = UserInputService:GetMouseLocation()
                    
                    local deltaX = (screenPos.X - mousePos.X) * aimSmoothing
                    local deltaY = (screenPos.Y - mousePos.Y) * aimSmoothing
                    
                    mousemoverel(deltaX, deltaY)
                else
                    local targetCFrame = CFrame.lookAt(camera.CFrame.Position, predictedPos)
                    camera.CFrame = camera.CFrame:Lerp(targetCFrame, aimSmoothing) 
                end

                local currentTime = os.clock()
                
                if currentTime - lastAutoShootTime > 0.05 then 
                    lastAutoShootTime = currentTime
                    local character = LocalPlayer.Character
                    local tool = character and character:FindFirstChildOfClass("Tool")
                    
                    if hitSoundEnabled then
                        local soundClone = hitSound:Clone()
                        soundClone.Parent = game:GetService("SoundService")
                        soundClone:Play()
                        game:GetService("Debris"):AddItem(soundClone, 2) 
                    end
                    
                    if typeof(mouse1press) == "function" and typeof(mouse1release) == "function" then
                        pcall(mouse1press)
                        task.delay(0.05, function() pcall(mouse1release) end)
                    elseif typeof(mouse1click) == "function" then 
                        pcall(mouse1click) 
                    end
                    
                    if tool then
                        tool:Activate() 
                    end
                    
                    if tracersEnabled and not isShooting then
                        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") and LocalPlayer.Character.Humanoid.Health > 0 then
                            local startPos = getTracerOrigin()
                            if startPos then 
                                createTracer(startPos, bestTargetPos)
                            end
                        end
                    end
                end
            end
        else
            lastSeenEnemy = nil
            timeInSight = 0
        end
    end

    -- Auto Crouch
    if autoCrouchEnabled then
        if isAutoShooting and not isCurrentlyCrouched then
            isCurrentlyCrouched = true
            VirtualInputManager:SendKeyEvent(true, crouchKey, false, game)
        elseif not isAutoShooting and isCurrentlyCrouched then
            isCurrentlyCrouched = false
            VirtualInputManager:SendKeyEvent(false, crouchKey, false, game)
        end
    end

    -- Dynamic Pattern Recoil Compensator
    if recoilControlEnabled and (isShooting or isAutoShooting) then
        if not isAutoShooting then
            local character = LocalPlayer.Character
            if character and character:FindFirstChildOfClass("Tool") then
                
                local elapsed = os.clock() - sprayStartTime
                local pullX = 0
                local pullY = 0
                
                if rcsPattern == "AK-47" then
                    if elapsed < 0.7 then
                        pullY = recoilStrength * 1.5
                        pullX = -recoilStrength * 0.3 
                    elseif elapsed < 1.3 then
                        pullY = recoilStrength * 0.2
                        pullX = -recoilStrength * 1.5 
                    elseif elapsed < 2.0 then
                        pullY = 0
                        pullX = recoilStrength * 1.5  
                    elseif elapsed < 3.0 then
                        pullY = 0
                        pullX = -recoilStrength * 1.5 
                    end
                else
                    pullY = recoilStrength
                    pullX = 0
                end

                if recoilMethod == "Mouse" and typeof(mousemoverel) == "function" then
                    mousemoverel(pullX * deltaTime * 100, pullY * deltaTime * 100)
                else
                    local camera = workspace.CurrentCamera
                    camera.CFrame = camera.CFrame * CFrame.Angles(math.rad(-pullY * deltaTime * 10), math.rad(-pullX * deltaTime * 10), 0)
                end
            end
        end
    end
end))

